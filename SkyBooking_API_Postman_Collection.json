  "item": [
    {
      "name": "🔐 AUTHENTICATION",
      "item": [
        {
          "name": "1️⃣ Register User Baru",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"John Doe\",\n  \"email\": \"john@email.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/auth/register",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "auth",
                "register"
              ]
            },
            "description": "Register user baru ke sistem"
          },
          "response": []
        },
        {
          "name": "2️⃣ Login & Dapatkan Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// Test 1: Validasi status code",
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "// Test 2: Response adalah JSON valid",
                  "pm.test(\"Response is valid JSON\", function () {",
                  "    pm.response.to.be.json;",
                  "});",
                  "",
                  "// Test 3: Field success harus true",
                  "pm.test(\"Response success is true\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.success).to.be.true;",
                  "});",
                  "",
                  "// Test 4: Simpan token ke environment untuk digunakan request lain",
                  "var jsonData = pm.response.json();",
                  "if (jsonData.token) {",
                  "    pm.environment.set(\"token\", jsonData.token);",
                  "    console.log(\"✅ Token berhasil disimpan: \" + jsonData.token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"test@email.com\",\n  \"password\": \"123456\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/auth/login",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "auth",
                "login"
              ]
            },
            "description": "Login dan dapatkan JWT token untuk authenticated requests"
          },
          "response": []
        },
        {
          "name": "3️⃣ Logout",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/auth/logout",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "auth",
                "logout"
              ]
            },
            "description": "Logout dan clear session"
          },
          "response": []
        }
      ],
      "description": "Authentication endpoints: Register, Login, Logout"
    },
    {
      "name": "✈️ FLIGHTS",
      "item": [
        {
          "name": "1️⃣ GET Semua Penerbangan",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"Response has data array\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.success).to.be.true;",
                  "    pm.expect(jsonData.data).to.be.an('array');",
                  "});",
                  "",
                  "pm.test(\"Flight has required fields\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    var flight = jsonData.data[0];",
                  "    pm.expect(flight).to.have.property('id');",
                  "    pm.expect(flight).to.have.property('flightNumber');",
                  "    pm.expect(flight).to.have.property('from');",
                  "    pm.expect(flight).to.have.property('to');",
                  "    pm.expect(flight).to.have.property('price');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/flights",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "flights"
              ]
            },
            "description": "Ambil data semua penerbangan"
          },
          "response": []
        },
        {
          "name": "2️⃣ GET Search Penerbangan",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"Search returns filtered results\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.success).to.be.true;",
                  "    pm.expect(jsonData).to.have.property('count');",
                  "    pm.expect(jsonData.data).to.be.an('array');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/flights/search?from=Jakarta&to=Bali&date=2026-05-15",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "flights",
                "search"
              ],
              "query": [
                {
                  "key": "from",
                  "value": "Jakarta"
                },
                {
                  "key": "to",
                  "value": "Bali"
                },
                {
                  "key": "date",
                  "value": "2026-05-15"
                }
              ]
            },
            "description": "Cari penerbangan berdasarkan asal, tujuan, dan tanggal"
          },
          "response": []
        },
        {
          "name": "3️⃣ GET Detail Penerbangan (by ID)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"Flight detail has all required fields\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    var flight = jsonData.data;",
                  "    pm.expect(flight).to.have.property('id');",
                  "    pm.expect(flight).to.have.property('flightNumber');",
                  "    pm.expect(flight).to.have.property('airline');",
                  "    pm.expect(flight).to.have.property('availableSeats');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/flights/1",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "flights",
                "1"
              ]
            },
            "description": "Ambil detail penerbangan spesifik berdasarkan ID"
          },
          "response": []
        }
      ],
      "description": "Flight related endpoints"
    },
    {
      "name": "🎫 BOOKINGS",
      "item": [
        {
          "name": "1️⃣ POST Confirm Booking",
