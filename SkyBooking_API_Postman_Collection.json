              "mode": "raw",
              "raw": "{\n  \"flight\": {\n    \"id\": 1,\n    \"flightNumber\": \"GA101\",\n    \"price\": 500000\n  },\n  \"passengers\": [\n    {\n      \"name\": \"John Doe\",\n      \"email\": \"john@email.com\",\n      \"phone\": \"081234567890\",\n      \"seatNumber\": \"12A\"\n    }\n  ],\n  \"contact\": {\n    \"name\": \"John Doe\",\n    \"email\": \"john@email.com\",\n    \"phone\": \"081234567890\"\n  },\n  \"paymentMethod\": \"credit_card\",\n  \"totalPrice\": 500000\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/bookings/confirm",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "bookings",
                "confirm"
              ]
            },
            "description": "Konfirmasi booking penerbangan"
          },
          "response": []
        }
      ],
      "description": "Booking related endpoints"
    },
    {
      "name": "👤 USERS",
