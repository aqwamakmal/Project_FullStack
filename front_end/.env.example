# ============================================================================
# ENVIRONMENT VARIABLES
# ============================================================================
# 
# File ini adalah CONTOH environment variables.
# Copy file ini ke .env dan sesuaikan nilainya.
#
# CARA PAKAI:
# 1. Copy file ini: cp .env.example .env
# 2. Edit .env sesuai kebutuhan
# 3. Jangan commit .env ke git!
#
# ============================================================================

# API Backend URL
# Development: http://localhost:5000
# Production: https://api.yourdomain.com
VITE_API_URL=http://localhost:5000

# Mode aplikasi (development / production)
# Ini otomatis di-set oleh Vite, tidak perlu diubah
# NODE_ENV=development
